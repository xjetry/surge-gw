# 必填:远程 mihomo 订阅 URL
SUBSCRIPTION_URL=https://example.com/your-subscription.yaml

# HTTP 监听端口(网关秒回 /surge 的端口;写进 Surge 托管配置的 URL 也用它)
HTTP_PORT=8080

# 可选覆盖(留空即用默认;compose 经 env_file 读取本文件,取消注释即生效):
# MAX_NODES=100
# GEOSITE_URL=https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geosite.dat
# REFRESH_INTERVAL=21600        # 后台自动刷新间隔(秒,默认 6h)
# MIN_REFRESH_INTERVAL=300      # 刷新防抖窗口(秒);/surge nudge 与 POST /refresh 共用
# RULESET_UPDATE_INTERVAL=86400 # 自托管 ruleset 行的 update-interval(秒);Surge 据此回拉 /ruleset → 触发按需重抓,调小提高新鲜度
# RULESET_LIVE_TIMEOUT=6        # GET /ruleset 按需重拉上游 rule-provider 的超时(秒);超时回退缓存
# EMIT_DOMAIN_SET=false         # 是否输出 DOMAIN-SET;Surge 的 DOMAIN-SET 无自动更新通道,默认 false 改用可更新的 RULE-SET
